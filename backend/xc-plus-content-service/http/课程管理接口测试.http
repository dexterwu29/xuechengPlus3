###############################################################################
# 五、课程营销
###############################################################################

### 5.1 获取营销（成功）
GET {{baseUrl}}/courses/1/market
X-Company-Id: {{companyId}}

### 5.2 保存营销-收费（成功）
PUT {{baseUrl}}/courses/1/market
Content-Type: application/json
X-Company-Id: {{companyId}}

{
  "charge": "201001",
  "price": 199.00,
  "originalPrice": 299.00,
  "qq": "123456",
  "wechat": "wxid_test",
  "phone": "13800138000",
  "validDays": 365
}

### 5.3 保存营销-免费（成功）
PUT {{baseUrl}}/courses/1/market
Content-Type: application/json
X-Company-Id: {{companyId}}

{
  "charge": "201000",
  "price": 0.00,
  "originalPrice": 0.00,
  "qq": null,
  "wechat": null,
  "phone": null,
  "validDays": 365
}

### 5.4 保存营销-失败-价格非法
PUT {{baseUrl}}/courses/1/market
Content-Type: application/json
X-Company-Id: {{companyId}}

{
  "charge": "201001",
  "price": -100,
  "originalPrice": 299.00,
  "validDays": 365
}

